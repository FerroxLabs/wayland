      "method": "api-key",
      "providerName": "Home Assistant",
      "providerSignupUrl": "https://www.home-assistant.io"
    },
    "toolGroups": [
      { "label": "Devices", "count": 6 },
      { "label": "Scenes", "count": 3 },
      { "label": "Automations", "count": 3 }

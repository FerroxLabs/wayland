{
  "$schema": "../schema/entry.schema.json",
  "name": "io.home-assistant/mcp-server",
  "title": "Home Assistant",
  "description": "Smart-home control — lights, climate, locks, scenes, automations — via your Home Assistant instance.",
  "version": "2025.5.0",
  "websiteUrl": "https://www.home-assistant.io/integrations/mcp_server/",
  "repository": { "url": "https://github.com/home-assistant/core", "source": "github" },
